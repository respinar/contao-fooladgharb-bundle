{
    "name": "respinar/fooladgharb-request-bundle",
    "description": "A Request table bundle for Contao CMS",
    "keywords": ["contao", "request", "bundle"],
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Hamid Peywasti",
            "email": "hamid@respinar.com",
            "homepage": "https://respinar.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/respinar/fooladgharb-request-bundle/issues",
        "source": "https://github.com/respinar/fooladgharb-request-bundle"
    },
    "require": {
        "php": "^8.3",
        "contao/core-bundle":"^5.3"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "Respinar\\FooladgharbRequestBundle\\": "src/"
        }
    },    
    "extra": {
        "contao-manager-plugin": "Respinar\\FooladgharbRequestBundle\\ContaoManager\\Plugin"
    }
}
